# /opt/partnerscope/.env — production secrets
#
# Installed ONCE on the server (chmod 600, owner: deploy). NEVER commit.
# After changing, run `./deploy.sh` to pick up changes.

# ─── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=partnerscope
POSTGRES_PASSWORD=REPLACE_WITH_64_CHAR_RANDOM_STRING
POSTGRES_DB=partnerscope

# ─── Docker image tag (GitHub Actions sets this automatically) ───────────
API_IMAGE_TAG=latest
GITHUB_REPOSITORY=elshanmusayev/partnerscope-platform

# ─── Stripe (fill in when products are created) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_1NLOqbRxx0000000000starterXX
STRIPE_PRICE_PRO_INTRO=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_ENTERPRISE=

# ─── Transactional email ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=PartnerScope <noreply@partnerscope.eu>
RESEND_REPLY_TO=hello@partnerscope.eu

# ─── Session + JWT — generate with: openssl rand -hex 32 ─────────────────
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_32

# ─── Optional ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
SENTRY_DSN=
