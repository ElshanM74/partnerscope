# /opt/partnerscope/.env — production secrets
#
# Installed ONCE on the server (chmod 600, owner: deploy). NEVER commit.
# After changing, run `./deploy.sh` to pick up changes.

# ─── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=partnerscope
POSTGRES_PASSWORD=REPLACE_WITH_64_CHAR_RANDOM_STRING
POSTGRES_DB=partnerscope

# ─── Docker image tag (GitHub Actions sets this automatically) ───────────
API_IMAGE_TAG=latest
GITHUB_REPOSITORY=elshanmusayev/partnerscope-platform

# ─── Stripe (fill in when products are created) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO_INTRO=
STRIPE_PRICE_ENTERPRISE=

# ─── Transactional email ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=PartnerScope <noreply@partnerscope.eu>
RESEND_REPLY_TO=hello@partnerscope.eu

# ─── Session + JWT — generate with: openssl rand -hex 32 ─────────────────
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_32

# ─── Optional ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
SENTRY_DSN=

# ─── APNs (Apple Push Notifications) — required for iOS push delivery ───
#
# Provision an auth key at:
#   https://developer.apple.com/account/resources/authkeys/list
# Download AuthKey_XXXXXXXXXX.p8 and base64-encode:
#   base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
#
# If any of these are blank the API logs a warning and no-ops the sender —
# /v1/push/register still succeeds, so the iOS app can register tokens
# before APNs credentials are provisioned.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_P8_KEY=
APNS_TOPIC=eu.partnerscope.app
# Flip to `true` once the app is live on the App Store (not TestFlight).
APNS_PRODUCTION=false
