# ──────────────────────────────────────────────────────────────────
# PartnerScope Platform — environment variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env (never committed) and fill in real values.

NODE_ENV=development
LOG_LEVEL=info

# ── API ─────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL 16+) ───────────────────────────────
DATABASE_URL=postgres://partnerscope:partnerscope@localhost:5432/partnerscope_dev

# ── Redis (queues, cache, rate limiting) ────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 / Object storage (evidence docs, reports) ────────────
S3_ENDPOINT=
S3_BUCKET=partnerscope-evidence
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@partnerscope.eu
RESEND_FROM_NAME=PartnerScope

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_starter_99
STRIPE_PRICE_PRO=price_pro_499
STRIPE_PRICE_PRO_INTRO=price_pro_299_intro
STRIPE_PRICE_ENTERPRISE=price_enterprise_4900_qtr
STRIPE_PRICE_ENTERPRISE_ADDVENDOR=price_enterprise_addvendor_199_qtr

# ── OpenAI (Annex III classifier, analyst assistive) ────────
OPENAI_API_KEY=

# ── HIBP Enterprise (breach lookup) ─────────────────────────
HIBP_API_KEY=

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
SESSION_SECRET=change_me_too

# ── Observability (optional) ────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
