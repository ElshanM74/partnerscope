---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.svg',
} = Astro.props;

// Locale detection: paths under /de/* render the German layout shell.
// Default fallback meta description differs per locale.
const path = Astro.url.pathname;
const isDe = path === '/de' || path === '/de/' || path.startsWith('/de/');
const locale = isDe ? 'de' : 'en';
const htmlLang = isDe ? 'de' : 'en';
const ogLocale = isDe ? 'de_DE' : 'en_US';

const defaultDescriptionEn =
  'Third-party AI risk assessment for EU buyers. Automated tests, documentary review and AI red-teaming across 13 dimensions. EU AI Act, GDPR, DORA, NIS2.';
const defaultDescriptionDe =
  'Drittparteien-Risikobewertung mit KI für europäische Einkäufer. Automatisierte Tests, Dokumentenprüfung und KI-Red-Teaming über 13 Dimensionen. EU AI Act, DSGVO, DORA, NIS2.';
const resolvedDescription = description ?? (isDe ? defaultDescriptionDe : defaultDescriptionEn);

// Map a current path to its EN / DE counterpart for the language switcher
// and hreflang alternates. Strips a leading /de when present, then re-prefixes
// for the German href.
const pathWithoutDe = isDe ? path.replace(/^\/de(?=\/|$)/, '') || '/' : path;
const enHref = pathWithoutDe;
const deHref = pathWithoutDe === '/' ? '/de' : '/de' + pathWithoutDe;
const switchLocaleHref = isDe ? enHref : deHref;
const switchLocaleLabel = isDe ? 'EN' : 'DE';
const switchLocaleAria = isDe ? 'Switch to English' : 'Auf Deutsch wechseln';

// Localized nav + footer strings
const t = isDe
  ? {
      navPricing: 'Preise',
      navSnapshot: 'Kostenloser Snapshot',
      navFaq: 'FAQ',
      navLogin: 'Anmelden',
      navSignup: 'Registrieren',
      navAccount: 'Konto',
      navDashboard: 'Dashboard',
      navAdmin: 'Admin',
      footerLegal: 'EKM Global Consulting GmbH · Geschäftsführer Elshan Musayev · Baden-Baden, DE · Siehe',
      footerImprint: 'Impressum',
      footerCopyright: 'PartnerScope. Alle Rechte vorbehalten.',
      appsLabel: 'Holen Sie sich die PartnerScope-App',
      appsAppStoreLine1: 'Laden im',
      appsAppStoreLine2: 'App Store',
      appsAppStoreAria: 'PartnerScope im App Store laden',
      appsPlayLine1: 'JETZT BEI',
      appsPlayLine2: 'Google Play',
      appsPlayAria: 'PartnerScope bei Google Play holen',
      footerNavTerms: 'AGB',
      footerNavPrivacy: 'Datenschutz',
      footerNavDpa: 'AVV',
      footerNavSubprocessors: 'Unterauftragsverarbeiter',
      footerNavImprint: 'Impressum',
      footerNavContact: 'Kontakt',
    }
  : {
      navPricing: 'Pricing',
      navSnapshot: 'Free snapshot',
      navFaq: 'FAQ',
      navLogin: 'Log in',
      navSignup: 'Sign up',
      navAccount: 'Account',
      navDashboard: 'Dashboard',
      navAdmin: 'Admin',
      footerLegal: 'EKM Global Consulting GmbH · Managing Director Elshan Musayev · Baden-Baden, DE · See',
      footerImprint: 'Impressum',
      footerCopyright: 'PartnerScope. All rights reserved.',
      appsLabel: 'Get the PartnerScope app',
      appsAppStoreLine1: 'Download on the',
      appsAppStoreLine2: 'App Store',
      appsAppStoreAria: 'Download PartnerScope on the App Store',
      appsPlayLine1: 'GET IT ON',
      appsPlayLine2: 'Google Play',
      appsPlayAria: 'Get PartnerScope on Google Play',
      footerNavTerms: 'Terms',
      footerNavPrivacy: 'Privacy',
      footerNavDpa: 'DPA',
      footerNavSubprocessors: 'Sub-processors',
      footerNavImprint: 'Impressum',
      footerNavContact: 'Contact',
    };

// Locale-prefixed paths for nav + footer
const p = (route: string) => (isDe ? '/de' + route : route);

const year = new Date().getFullYear();
const site = Astro.site ?? new URL('https://partnerscope.eu');
// Strip .html and trailing /index from pathname for canonical (trailingSlash: 'never' +
// build.format: 'file' otherwise emits canonical URLs with .html, fragmenting from
// public/*.html static articles that use clean no-extension URLs as canonical).
const cleanPath = Astro.url.pathname
  .replace(/\.html$/, '')
  .replace(/\/index$/, '/')
  .replace(/\/$/, '') || '/';
const canonicalHref = canonical ?? new URL(cleanPath, site).toString();
const ogImageHref = new URL(ogImage, site).toString();
const enAlternateHref = new URL(enHref, site).toString();
const deAlternateHref = new URL(deHref, site).toString();

// Schema.org JSON-LD — Organization (always) + SoftwareApplication (homepage/pricing only).
// PartnerScope is a brand of EKM Global Consulting GmbH (Baden-Baden, founded Jan 2013).
// LinkedIn: EKMGC main page + PartnerScope Showcase Page (id 121553912).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://partnerscope.eu/#organization',
  name: 'PartnerScope',
  url: 'https://partnerscope.eu',
  logo: {
    '@type': 'ImageObject',
    url: 'https://partnerscope.eu/logo.png',
    width: 1024,
    height: 1024,
  },
  image: {
    '@type': 'ImageObject',
    url: 'https://partnerscope.eu/logo.png',
  },
  description:
    'Third-party AI risk assessment platform for DACH-regulated organizations. EU AI Act classification, AI red-teaming, and 13-dimension risk scoring — without the 40-page questionnaire.',
  inLanguage: isDe ? 'de-DE' : 'en-GB',
  foundingDate: '2024',
  founder: {
    '@type': 'Person',
    '@id': 'https://www.linkedin.com/in/elshan-musayev/#person',
    name: 'Elshan Musayev',
    url: 'https://www.linkedin.com/in/elshan-musayev/',
    jobTitle: 'Founder',
    email: 'elshan.musayev@partnerscope.eu',
    sameAs: [
      'https://www.linkedin.com/in/elshan-musayev/',
      'https://www.linkedin.com/in/elshanmusayev/',
      'https://elshanmusayev.com',
    ],
  },
  parentOrganization: {
    '@type': 'Organization',
    '@id': 'https://ekmgc.de/#organization',
    name: 'EKM Global Consulting GmbH',
    url: 'https://ekmgc.de',
    foundingDate: '2013-01',
    sameAs: [
      'https://www.linkedin.com/company/ekm-global-consulting-gmbh/',
      'https://www.linkedin.com/showcase/121553912/',
      'https://www.linkedin.com/showcase/121603994/',
      'https://www.crunchbase.com/organization/ekm-global-consulting',
    ],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Baden-Baden',
      addressCountry: 'DE',
    },
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Baden-Baden',
    addressRegion: 'Baden-Württemberg',
    addressCountry: 'DE',
  },
  areaServed: [
    { '@type': 'Country', name: 'Germany' },
    { '@type': 'Country', name: 'Austria' },
    { '@type': 'Country', name: 'Switzerland' },
    { '@type': 'Place', name: 'European Union' },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'elshan.musayev@partnerscope.eu',
    contactType: 'Sales',
    availableLanguage: ['en', 'de'],
  },
  sameAs: [
    'https://www.linkedin.com/company/ekm-global-consulting-gmbh/',
    'https://www.linkedin.com/showcase/121553912/',
    'https://www.crunchbase.com/organization/ekm-global-consulting',
  ],
};

const isHomepageOrPricing =
  path === '/' ||
  path === '/plans' ||
  path === '/plans.html' ||
  path === '/de' ||
  path === '/de/' ||
  path === '/de/plans' ||
  path === '/de/plans.html';

const softwareSchema = isHomepageOrPricing
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      '@id': 'https://partnerscope.eu/#software',
      name: 'PartnerScope',
      applicationCategory: 'BusinessApplication',
      applicationSubCategory: 'Third-Party Risk Management',
      operatingSystem: 'Web (SaaS)',
      url: 'https://partnerscope.eu',
      inLanguage: isDe ? 'de-DE' : 'en-GB',
      description:
        'EU AI Act-aware third-party risk assessment platform. Replaces 40-page questionnaires with automated security checks, documentary review, AI red-teaming, and EU AI Act classification across 13 risk dimensions.',
      softwareVersion: '2025',
      publisher: { '@id': 'https://partnerscope.eu/#organization' },
      offers: [
        {
          '@type': 'Offer',
          name: 'Starter',
          price: '99',
          priceCurrency: 'EUR',
          description: 'One-time, single vendor',
          availability: 'https://schema.org/InStock',
        },
        {
          '@type': 'Offer',
          name: 'Pro',
          price: '299',
          priceCurrency: 'EUR',
          description: 'One-time with AI red-teaming',
          availability: 'https://schema.org/InStock',
        },
        {
          '@type': 'Offer',
          name: 'Enterprise',
          price: '4900',
          priceCurrency: 'EUR',
          description: 'Quarterly, 15-vendor minimum, continuous monitoring',
          availability: 'https://schema.org/InStock',
        },
      ],
    }
  : null;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalHref} />

    <link rel="alternate" hreflang="en" href={enAlternateHref} />
    <link rel="alternate" hreflang="de" href={deAlternateHref} />
    <link rel="alternate" hreflang="x-default" href={enAlternateHref} />

    <meta property="og:site_name" content="PartnerScope" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageHref} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageHref} />

    <meta name="theme-color" content="#0f1a2b" />
    <meta name="robots" content="index, follow" />

    <meta name="google-site-verification" content="kWlqOezw2lIIz-xdKtssLNxNcCMKjN4-9oNMffOB2Ng" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="text/plain" title="LLM Manifest" href="/llms.txt" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
    {softwareSchema && <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>}
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href={p('/plans')}>
          <span class="brand-mark">◆</span>
          <span class="brand-name">PartnerScope</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={p('/plans')}>{t.navPricing}</a>
          <a href={p('/plans') + '#snapshot'}>{t.navSnapshot}</a>
          <a href={p('/plans') + '#faq'}>{t.navFaq}</a>
          <a class="lang-switch" href={switchLocaleHref} aria-label={switchLocaleAria}>{switchLocaleLabel}</a>
          <span
            id="nav-auth-slot"
            class="nav-auth"
            data-locale={locale}
            data-loc-dashboard={t.navDashboard}
            data-loc-admin={t.navAdmin}
          >
            <a href={p('/login')} class="nav-login">{t.navLogin}</a>
            <a class="btn btn-dark nav-cta" href={p('/signup')}>{t.navSignup}</a>
          </span>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer-inner">
        <div class="footer-left">
          <div class="footer-brand">
            <span class="brand-mark">◆</span>
            <span class="brand-name">PartnerScope</span>
          </div>
          <p class="footer-legal">
            {t.footerLegal} <a class="footer-inline" href={p('/legal/imprint')}>{t.footerImprint}</a><br />
            © {year} {t.footerCopyright}
          </p>
        </div>
        <div class="footer-apps">
          <p class="footer-apps-label">{t.appsLabel}</p>
          <div class="footer-apps-row">
            <a
              class="app-badge"
              href="https://apps.apple.com/app/partnerscope/id6762094242"
              aria-label={t.appsAppStoreAria}
              target="_blank"
              rel="noopener"
            >
              <svg class="app-badge-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M17.5 12.5c-.03-2.66 2.17-3.94 2.27-4-1.24-1.81-3.17-2.06-3.85-2.09-1.64-.17-3.2 .96-4.03 .96-.84 0-2.12-.94-3.49-.91-1.79 .03-3.45 1.04-4.37 2.64-1.86 3.23-.48 8.02 1.34 10.65 .89 1.29 1.94 2.74 3.31 2.69 1.33-.05 1.83-.86 3.44-.86 1.6 0 2.06 .86 3.46 .83 1.43-.03 2.34-1.31 3.21-2.61 1.01-1.49 1.43-2.93 1.45-3-.03-.01-2.78-1.07-2.81-4.3zM14.85 4.84c.74-.89 1.23-2.13 1.1-3.36-1.06 .04-2.34 .7-3.1 1.59-.68 .79-1.27 2.05-1.11 3.26 1.18 .09 2.38-.6 3.11-1.49z" />
              </svg>
              <span class="app-badge-text">
                <span class="app-badge-line1">{t.appsAppStoreLine1}</span>
                <span class="app-badge-line2">{t.appsAppStoreLine2}</span>
              </span>
            </a>
            <a
              class="app-badge"
              href="https://play.google.com/store/apps/details?id=eu.partnerscope.app"
              aria-label={t.appsPlayAria}
              target="_blank"
              rel="noopener"
            >
              <svg class="app-badge-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M3.5 20.7V3.3c0-.66 .55-1.07 1.07-.84l13.21 8.7c.5 .27 .5 .97 0 1.24l-13.21 8.7c-.52 .23-1.07-.18-1.07-.84z" />
              </svg>
              <span class="app-badge-text">
                <span class="app-badge-line1">{t.appsPlayLine1}</span>
                <span class="app-badge-line2">{t.appsPlayLine2}</span>
              </span>
            </a>
          </div>
        </div>
        <nav class="footer-nav" aria-label={isDe ? 'Rechtliches' : 'Legal'}>
          <a href={p('/legal/terms')}>{t.footerNavTerms}</a>
          <a href={p('/legal/privacy')}>{t.footerNavPrivacy}</a>
          <a href={p('/legal/dpa')}>{t.footerNavDpa}</a>
          <a href={p('/legal/sub-processors')}>{t.footerNavSubprocessors}</a>
          <a href={p('/legal/imprint')}>{t.footerNavImprint}</a>
          <a href="mailto:elshan.musayev@partnerscope.eu">{t.footerNavContact}</a>
        </nav>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: saturate(160%) blur(8px);
        border-bottom: 1px solid var(--ps-border);
      }
      .site-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.85rem;
        padding-bottom: 0.85rem;
      }
      .brand,
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--ps-ink);
        font-weight: 700;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .brand-mark {
        color: var(--ps-accent-strong);
        font-size: 1.1rem;
      }
      .brand-name {
        font-size: 1.05rem;
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .site-nav a {
        color: var(--ps-text);
        font-weight: 500;
        font-size: 0.95rem;
      }
      .site-nav a.nav-cta {
        color: var(--ps-paper);
      }
      .nav-auth {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
      }
      .nav-login {
        color: var(--ps-text);
      }
      .nav-admin {
        color: var(--ps-accent-strong);
        font-weight: 600;
      }
      .lang-switch {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--ps-muted);
        border: 1px solid var(--ps-border);
        border-radius: 999px;
        padding: 0.18rem 0.55rem;
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: color 120ms ease, border-color 120ms ease;
      }
      .lang-switch:hover {
        color: var(--ps-accent-strong);
        border-color: var(--ps-accent-strong);
      }
      @media (max-width: 720px) {
        .site-nav a:not(.nav-cta),
        .site-nav .nav-login {
          display: none;
        }
      }

      .site-footer {
        background: var(--ps-navy);
        color: #c8d1e3;
        padding: 3rem 0 2.5rem;
        margin-top: 4rem;
      }
      .site-footer .brand-name {
        color: var(--ps-paper);
      }
      .site-footer-inner {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .footer-legal {
        font-size: 0.85rem;
        margin-top: 0.75rem;
        color: #8894ae;
      }
      .footer-legal .footer-inline {
        color: #c8d1e3;
        text-decoration: underline;
        text-decoration-color: rgba(200, 209, 227, 0.3);
      }
      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
        align-items: center;
      }
      .footer-nav a {
        color: #c8d1e3;
        font-size: 0.9rem;
      }
      .footer-nav a:hover {
        color: var(--ps-paper);
      }

      .footer-apps {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        align-items: flex-start;
      }
      .footer-apps-label {
        font-size: 0.78rem;
        color: #8894ae;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
      }
      .footer-apps-row {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
      }
      .app-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        background: #0f172a;
        color: #ffffff;
        border: 1px solid #2a3756;
        border-radius: 0.55rem;
        padding: 0.45rem 0.85rem;
        text-decoration: none;
        line-height: 1.05;
        transition: background 120ms ease, border-color 120ms ease;
      }
      .app-badge:hover {
        background: #1e293b;
        border-color: #3a4970;
      }
      .app-badge-icon {
        width: 1.5rem;
        height: 1.5rem;
        flex-shrink: 0;
      }
      .app-badge-text {
        display: inline-flex;
        flex-direction: column;
      }
      .app-badge-line1 {
        font-size: 0.62rem;
        opacity: 0.85;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        font-weight: 500;
      }
      .app-badge-line2 {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      @media (max-width: 720px) {
        .footer-apps {
          align-items: center;
          width: 100%;
        }
        .footer-apps-row {
          justify-content: center;
        }
      }
    </style>

    <!--
      Header auth-state swap. If a ps_user blob is in localStorage, swap the
      "Log in / Sign up" CTA for a "Dashboard / <name>" pair. Purely cosmetic —
      the actual auth check happens server-side on every /api/v1/* call, and
      client-side on /dashboard + /account page loads.
    -->
    <script>
      (() => {
        const slot = document.getElementById('nav-auth-slot');
        if (!slot) return;
        try {
          const raw = localStorage.getItem('ps_user');
          if (!raw) return;
          const u = JSON.parse(raw);
          if (!u || typeof u !== 'object' || !u.email) return;
          const label = (u.fullName && String(u.fullName).trim()) || String(u.email).split('@')[0] || 'Account';

          // Locale-aware routing — read locale + localized labels from the
          // server-rendered nav slot. /dashboard, /admin, /account are
          // gated routes that don't have /de/ counterparts yet (the auth
          // shell stays in English internally), but we still respect the
          // locale on links so EN users don't get bounced into /de/* shells.
          const isDe = slot.dataset.locale === 'de';
          const dashLabel = slot.dataset.locDashboard || 'Dashboard';
          const adminLabel = slot.dataset.locAdmin || 'Admin';

          // textContent for the dynamic label — prevents reflected-XSS if anyone
          // ever puts a <script> in their fullName.
          const dash = document.createElement('a');
          dash.href = '/dashboard';
          dash.className = 'nav-login';
          dash.textContent = dashLabel;

          const children = [dash];

          // Staff-only link. Strict `=== true` so older ps_user blobs (lacking
          // the field) hide the link. Server still enforces 403 on /v1/admin/*.
          if (u.isStaff === true) {
            const admin = document.createElement('a');
            admin.href = '/admin';
            admin.className = 'nav-login nav-admin';
            admin.textContent = adminLabel;
            children.push(admin);
          }

          const acc = document.createElement('a');
          acc.href = '/account';
          acc.className = 'btn btn-dark nav-cta';
          acc.textContent = label;
          children.push(acc);

          slot.replaceChildren(...children);
        } catch {}
      })();
    </script>

    <!-- Sofia AI chat widget removed 2026-05-04: chatwidget2.js was lost in
         a prior rsync deploy and the script tag was generating 404s on every
         page view. Re-add when widget asset is restored on /var/www. -->
  </body>
</html>
