---
interface Tier {
  name: string;
  priceLabel: string;
  priceSub: string;
  highlight?: boolean;
  badge?: string;
  tagline: string;
  bestFor: string;
  features: string[];
  cta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  finePrint?: string;
}

const TIERS: Tier[] = [
  {
    name: 'Starter',
    priceLabel: '€99',
    priceSub: 'Single vendor · 24h SLA · one-time',
    tagline: 'Spot-check a vendor, or stress-test our methodology.',
    bestFor: 'Spot-checking a new vendor, or stress-testing our methodology.',
    features: [
      'Automated checks: DNS/TLS, security headers, breach history, mail deliverability, basic sanctions, CT log scan',
      '39-question self-service questionnaire',
      '5–8 page PDF report with risk scorecard, top concerns, upgrade path',
      'Valid 90 days',
    ],
    cta: { label: 'Start a Starter assessment →', href: '/get-started?tier=starter' },
    finePrint: 'SEPA / card payment via Stripe. Instant delivery of portal link.',
  },
  {
    name: 'Pro',
    priceLabel: '€299',
    priceSub: 'Launch price until 30 Jun 2026 · normally €499 · 48h SLA',
    highlight: true,
    badge: 'Most popular',
    tagline: 'Serious vendor decisions — new contract, renewal, audit response.',
    bestFor: 'Serious vendor decisions — new contract, renewal, audit response.',
    features: [
      'Everything in Starter, plus:',
      'Full 78-question analysis across all 13 dimensions',
      'Documentary review (DPA, ISO 27001, SOC 2, Model Card, SBOM, BCP, IR plan)',
      'Sanctions + adverse media + PEP + UBO verification (DACH + global)',
      'Credit score + insolvency check',
      'AI red-team (5 payloads: prompt injection · jailbreak · PII leakage)',
      'EU AI Act Annex III classification + obligations gap',
      '20–30 page report + remediation checklist',
      'Analyst + QA reviewer named on report',
      'Valid 180 days · 72h re-score included',
    ],
    cta: { label: 'Start a Pro assessment →', href: '/get-started?tier=pro' },
    secondaryCta: { label: 'Book a 15-min demo →', href: 'mailto:hello@partnerscope.eu?subject=PartnerScope%20Pro%20demo' },
  },
  {
    name: 'Enterprise',
    priceLabel: '€4 900',
    priceSub: 'per quarter · 15-vendor minimum · 24h SLA · SSO',
    tagline: '15+ vendors, regulated industries, ongoing compliance posture.',
    bestFor: '15+ vendors, regulated industries, ongoing compliance posture.',
    features: [
      'Everything in Pro, plus:',
      'Continuous monitoring — 11 signals polled weekly (breach, sanctions, cert, UBO, model, SBOM CVEs…)',
      '25-payload AI red-team suite (injection, jailbreak, PII, bias, robustness, agentic abuse)',
      'Human intelligence — reference calls, ex-employee interviews, site visits on request',
      '4th-party supply-chain mapping + concentration risk',
      'Dashboard with SSO (SAML 2.0, OIDC)',
      'GRC integrations: ServiceNow, Archer, OneTrust, SAP Ariba, Coupa',
      'SIEM webhook: Splunk, Sentinel, Slack, Teams',
      'Dedicated analyst + quarterly exec briefing',
      'Additional vendors €199 / vendor / quarter',
    ],
    cta: { label: 'Book Enterprise call →', href: 'mailto:hello@partnerscope.eu?subject=PartnerScope%20Enterprise%20call' },
    finePrint: 'One-time onboarding €2 500 (SSO, integrations, portfolio import).',
  },
];
---

<section id="tiers" class="tiers section">
  <div class="container">
    <div class="tiers-head">
      <p class="eyebrow">Pricing</p>
      <h2>Three tiers. One methodology.</h2>
      <p class="tiers-sub">
        Every tier shares the 13-dimension framework. The difference is depth: which tests we run,
        how many questions, whether a named analyst signs the report, and whether we keep watching
        after delivery.
      </p>
    </div>

    <div class="tiers-grid">
      {TIERS.map((t) => (
        <article class={`tier ${t.highlight ? 'tier-highlight' : ''}`}>
          {t.badge && <div class="tier-badge">{t.badge}</div>}
          <h3 class="tier-name">{t.name}</h3>
          <div class="tier-price">
            <span class="tier-price-amount">{t.priceLabel}</span>
          </div>
          <div class="tier-price-sub">{t.priceSub}</div>
          <p class="tier-tagline">{t.tagline}</p>
          <ul class="tier-features">
            {t.features.map((f) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="tier-cta">
            <a class={`btn ${t.highlight ? 'btn-primary' : 'btn-dark'}`} href={t.cta.href}>
              {t.cta.label}
            </a>
            {t.secondaryCta && (
              <a class="tier-cta-secondary" href={t.secondaryCta.href}>{t.secondaryCta.label}</a>
            )}
          </div>
          {t.finePrint && <p class="tier-fine">{t.finePrint}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tiers-head {
    max-width: 680px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }
  .eyebrow {
    color: var(--ps-accent-strong);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    margin: 0;
  }
  .tiers-sub {
    color: var(--ps-muted);
    margin: 0.5rem auto 0;
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }
  @media (max-width: 1000px) {
    .tiers-grid {
      grid-template-columns: 1fr;
    }
  }

  .tier {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--ps-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.5rem 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .tier-highlight {
    border-color: var(--ps-accent);
    box-shadow:
      0 0 0 3px rgba(79, 124, 255, 0.12),
      var(--shadow-md);
  }
  .tier-badge {
    position: absolute;
    top: -0.75rem;
    left: 1.5rem;
    background: var(--ps-accent-strong);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .tier-name {
    margin: 0;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ps-muted);
    font-weight: 700;
  }
  .tier-price-amount {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--ps-ink);
    letter-spacing: -0.02em;
  }
  .tier-price-sub {
    font-size: 0.85rem;
    color: var(--ps-muted);
    margin-bottom: 0.75rem;
  }
  .tier-tagline {
    color: var(--ps-text);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    gap: 0.55rem;
    flex: 1 1 auto;
  }
  .tier-features li {
    display: flex;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--ps-text);
    align-items: flex-start;
  }
  .tier-features svg {
    color: var(--ps-accent-strong);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .tier-cta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tier-cta .btn {
    width: 100%;
  }
  .tier-cta-secondary {
    display: block;
    text-align: center;
    color: var(--ps-accent-strong);
    font-weight: 500;
    font-size: 0.9rem;
  }
  .tier-fine {
    color: var(--ps-muted);
    font-size: 0.8rem;
    margin-top: 0.85rem;
    text-align: center;
  }
</style>
