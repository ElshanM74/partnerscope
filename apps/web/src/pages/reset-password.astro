---
/**
 * /reset-password — token in ?token=…, new password form, POST to backend.
 *
 * On success: redirect to /login?reset=1 which shows a "Password updated,
 * please log in" banner. All token-related failures (missing, malformed,
 * expired, already used) surface as the same generic error.
 */
import Base from '../layouts/Base.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? '/api';
---
<Base
  title="Reset password — PartnerScope"
  description="Set a new password for your PartnerScope account."
>
  <section class="auth section">
    <div class="container auth-inner">
      <header class="auth-head">
        <h1>Reset password</h1>
        <p class="auth-sub">Choose a new password for your account.</p>
      </header>

      <p class="missing-token" id="missing-token" hidden>
        This reset link is missing or invalid. Please
        <a href="/forgot-password">request a new one</a>.
      </p>

      <form id="reset-form" class="auth-form" novalidate data-api-base={apiBase} hidden>
        <label class="full">
          <span>New password <em>*</em></span>
          <input type="password" name="password" required minlength="8" maxlength="128" autocomplete="new-password" />
        </label>

        <label class="full">
          <span>Confirm new password <em>*</em></span>
          <input type="password" name="confirm" required minlength="8" maxlength="128" autocomplete="new-password" />
        </label>

        <div class="actions">
          <button type="submit" class="btn btn-primary" id="reset-submit">Set new password →</button>
          <a class="btn btn-ghost" href="/login">Cancel</a>
        </div>

        <p class="tiny" id="reset-error" hidden></p>
      </form>
    </div>
  </section>
</Base>

<style>
  .auth-inner { max-width: 420px; }
  .auth-head { text-align: center; margin-bottom: 1.5rem; }
  .auth-sub { color: var(--ps-muted); margin-top: 0.25rem; }
  .auth-form {
    background: var(--ps-paper);
    border: 1px solid var(--ps-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }
  label { display: block; font-size: 0.9rem; color: var(--ps-text); }
  label.full { margin-bottom: 1rem; }
  label > span { display: block; margin-bottom: 0.35rem; font-weight: 500; }
  label em { color: var(--ps-accent-strong); font-style: normal; }
  input[type='password'] {
    width: 100%;
    border: 1px solid var(--ps-border);
    background: var(--ps-paper);
    color: var(--ps-ink);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    font-family: inherit;
  }
  input:focus { outline: none; border-color: var(--ps-accent); box-shadow: 0 0 0 3px rgba(79, 124, 255, 0.18); }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .missing-token {
    background: #fff7f6;
    border: 1px solid #f1c3be;
    color: #8a3b33;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .tiny { color: var(--band-high); font-size: 0.85rem; margin-top: 1rem; margin-bottom: 0; }
</style>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement | null;
  const submit = document.getElementById('reset-submit') as HTMLButtonElement | null;
  const errEl = document.getElementById('reset-error') as HTMLParagraphElement | null;
  const missingEl = document.getElementById('missing-token');

  const token = new URL(window.location.href).searchParams.get('token');

  if (!token) {
    if (missingEl) missingEl.hidden = false;
  } else if (form && submit && errEl) {
    form.hidden = false;
    const apiBase = form.dataset.apiBase || '/api';

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';
      const data = new FormData(form);
      const password = String(data.get('password') || '');
      const confirm = String(data.get('confirm') || '');

      if (password.length < 8) {
        errEl.textContent = 'Password must be at least 8 characters.';
        errEl.hidden = false;
        return;
      }
      if (password !== confirm) {
        errEl.textContent = 'Passwords do not match.';
        errEl.hidden = false;
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Updating…';
      try {
        const res = await fetch(`${apiBase}/v1/auth/reset-password`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ token, password }),
        });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          const msg = res.status === 400
            ? 'This reset link is invalid or has expired. Please request a new one.'
            : body?.message || `Request failed (${res.status}).`;
          throw new Error(msg);
        }
        // Drop any existing session — the password is now different and the
        // old JWT should no longer be trusted by the user in front of us.
        try {
          localStorage.removeItem('ps_token');
          localStorage.removeItem('ps_user');
        } catch {}
        window.location.href = '/login?reset=1';
      } catch (err: any) {
        errEl.textContent = err?.message || 'Unexpected error.';
        errEl.hidden = false;
        submit.disabled = false;
        submit.textContent = 'Set new password →';
      }
    });
  }
</script>
