---
/**
 * /forgot-password — email input, triggers POST /v1/auth/forgot-password,
 * then shows a uniform success message. Backend intentionally returns 200
 * whether or not the address maps to a real user, so the client must not
 * differentiate either (no enumeration).
 */
import Base from '../layouts/Base.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? '/api';
---
<Base
  title="Forgot password — PartnerScope"
  description="Recover access to your PartnerScope account."
>
  <section class="auth section">
    <div class="container auth-inner">
      <header class="auth-head">
        <h1>Forgot password?</h1>
        <p class="auth-sub">
          Enter your email and we'll send you a reset link.
        </p>
      </header>

      <form id="forgot-form" class="auth-form" novalidate data-api-base={apiBase}>
        <label class="full">
          <span>Email <em>*</em></span>
          <input type="email" name="email" required autocomplete="email" placeholder="you@company.com" />
        </label>

        <div class="actions">
          <button type="submit" class="btn btn-primary" id="forgot-submit">Send reset link →</button>
          <a class="btn btn-ghost" href="/login">Back to login</a>
        </div>

        <p class="tiny" id="forgot-error" hidden></p>
      </form>

      <div id="forgot-success" class="success-card" hidden>
        <p>
          If an account with that email exists, we've sent a reset link.
          The link expires in 30 minutes.
        </p>
        <p class="muted">
          Didn't receive anything? Check your spam folder, or
          <a href="/forgot-password">try again</a>.
        </p>
        <p><a class="btn btn-ghost" href="/login">Back to login</a></p>
      </div>
    </div>
  </section>
</Base>

<style>
  .auth-inner { max-width: 420px; }
  .auth-head { text-align: center; margin-bottom: 1.5rem; }
  .auth-sub { color: var(--ps-muted); margin-top: 0.25rem; }
  .auth-form, .success-card {
    background: var(--ps-paper);
    border: 1px solid var(--ps-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }
  .success-card p { margin: 0 0 0.9rem; }
  .success-card p:last-child { margin-bottom: 0; margin-top: 1.25rem; }
  label { display: block; font-size: 0.9rem; color: var(--ps-text); }
  label.full { margin-bottom: 1rem; }
  label > span { display: block; margin-bottom: 0.35rem; font-weight: 500; }
  label em { color: var(--ps-accent-strong); font-style: normal; }
  input[type='email'] {
    width: 100%;
    border: 1px solid var(--ps-border);
    background: var(--ps-paper);
    color: var(--ps-ink);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    font-family: inherit;
  }
  input:focus { outline: none; border-color: var(--ps-accent); box-shadow: 0 0 0 3px rgba(79, 124, 255, 0.18); }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .muted { color: var(--ps-muted); }
  .tiny { color: var(--band-high); font-size: 0.85rem; margin-top: 1rem; margin-bottom: 0; }
</style>

<script>
  const form = document.getElementById('forgot-form') as HTMLFormElement | null;
  const submit = document.getElementById('forgot-submit') as HTMLButtonElement | null;
  const errEl = document.getElementById('forgot-error') as HTMLParagraphElement | null;
  const successEl = document.getElementById('forgot-success') as HTMLElement | null;

  if (form && submit && errEl && successEl) {
    const apiBase = form.dataset.apiBase || '/api';

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      errEl.hidden = true;
      errEl.textContent = '';
      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();
      if (!email) return;

      submit.disabled = true;
      submit.textContent = 'Sending…';
      try {
        const res = await fetch(`${apiBase}/v1/auth/forgot-password`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (res.status === 429) {
          throw new Error('Too many requests. Please try again in a few minutes.');
        }
        if (!res.ok && res.status !== 200) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body?.message || `Request failed (${res.status}).`);
        }
        // Success — swap form for the uniform confirmation card.
        form.hidden = true;
        successEl.hidden = false;
      } catch (err: any) {
        errEl.textContent = err?.message || 'Unexpected error.';
        errEl.hidden = false;
        submit.disabled = false;
        submit.textContent = 'Send reset link →';
      }
    });
  }
</script>
