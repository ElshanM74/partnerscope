<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Your PartnerScope snapshot</title>
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f6f7f9; margin: 0; padding: 24px; color: #1a2233; }
      .card { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 10px; border: 1px solid #e5e8ec; overflow: hidden; }
      .hdr { padding: 20px 28px; background: #0f1a2b; color: #fff; font-weight: 600; letter-spacing: .4px; font-size: 15px; }
      .body { padding: 24px 28px; font-size: 15px; line-height: 1.55; }
      .score { font-size: 36px; font-weight: 700; color: #0f1a2b; }
      .band-HIGH { color: #c0392b; }
      .band-MEDIUM { color: #d67c00; }
      .band-LOW { color: #1f7a3d; }
      .band-MINIMAL { color: #0b5d2f; }
      .cta { display: inline-block; padding: 12px 20px; background: #0f1a2b; color: #fff !important; text-decoration: none; border-radius: 6px; font-weight: 600; }
      .muted { color: #6a7280; font-size: 13px; }
      ul { padding-left: 18px; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="hdr">PARTNERSCOPE · 60-second snapshot</div>
      <div class="body">
        <p>Hi,</p>
        <p>Your free snapshot for <strong>{{vendorDomain}}</strong>:</p>

        <div class="score">{{snapshotScore}} / 100</div>
        <div class="band-{{riskBand}}"><strong>Band: {{riskBand}}</strong></div>

        {{#if concerns.length}}
          <p><strong>Top concerns</strong></p>
          <ul>
            {{#each concerns}}<li>{{this}}</li>{{/each}}
          </ul>
        {{/if}}

        <p>Want the full picture?</p>
        <ul>
          <li><strong>Starter (€99)</strong> — 24h · automated tests + questionnaire</li>
          <li><strong>Pro (€299 intro / €499)</strong> — 48h · documentary review + red-team</li>
        </ul>

        <p><a class="cta" href="{{upgradeUrl}}">Upgrade</a></p>

        <p class="muted">— PartnerScope</p>
      </div>
    </div>
  </body>
</html>
